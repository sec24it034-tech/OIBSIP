# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/pizza-app

# JWT
JWT_SECRET=pizza-app-secret-key-change-in-production
JWT_EXPIRE=7d

# Email (Nodemailer)
EMAIL_SERVICE=gmail
EMAIL_USERNAME=pizzaapp2024@gmail.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=pizzaapp2024@gmail.com

# Razorpay (Test Mode)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Frontend URL
FRONTEND_URL=http://localhost:3000